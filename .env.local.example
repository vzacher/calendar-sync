# iCal URLs - ezeket a Booking.com és Airbnb admin felületéről kell másolni
AIRBNB_ICAL_URL=https://www.airbnb.com/calendar/ical/XXXXXXXX.ics?s=XXXXXXXX
BOOKING_ICAL_URL=https://ical.booking.com/v1/export?t=XXXXXXXX

# Twilio credentials - https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# A telefonszám, amire az SMS-t küldjük (pl. +36301234567)
ALERT_PHONE_NUMBER=+36XXXXXXXXX

# Cron biztonság - egy véletlenszerű titkos kulcs
CRON_SECRET=valami-titkos-kulcs-ide
